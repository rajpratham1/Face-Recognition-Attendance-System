SECRET_KEY=change-this-to-a-long-random-secret
FLASK_ENV=development
SESSION_COOKIE_SECURE=0
APP_TIMEZONE=Asia/Kolkata
DATABASE_URL=sqlite:///attendance.db
RATELIMIT_STORAGE_URI=memory://
INVERTIS_LAT=28.325764684367748
INVERTIS_LNG=79.46097110207619
ALLOWED_RADIUS_METERS=100
GEOFENCE_ENFORCED=0
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ─── Encrypted Backup Store Settings ───────────────────────
# Optional. If empty, defaults are used:
#   DB  -> instance/userbackup.db
#   KEY -> instance/userbackup.key
USER_BACKUP_DB_PATH=
USER_BACKUP_ENCRYPTION_KEY=
USER_BACKUP_KEY_PATH=


ADMIN_SECRET_VIEW_KEY=

# ─── Email Notification Settings ────────────────────────────
# Required for attendance email notifications.
# Use Gmail App Password (NOT your regular password).
# How to get App Password:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Go to App Passwords → Select "Mail" → Generate
#   3. Copy the 16-character password and paste below.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM_NAME=Attendance System
