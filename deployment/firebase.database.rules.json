{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "users": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "roles": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('roles').child(auth.uid).val() === 'admin')",
        ".write": "auth != null && root.child('roles').child(auth.uid).val() === 'admin'"
      }
    },

    "courses": {
      "$courseId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "sessions": {
      "$sessionId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "enrollments": {
      "$studentId": {
        "$courseId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },

    "attendance": {
      "students": {
        "$studentId": {
          "$sessionId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      },
      "sessions": {
        "$sessionId": {
          "$studentId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },

    "attendance_attempts": {
      "$date": {
        ".read": "auth != null",
        "$attemptId": {
          ".write": "auth != null"
        }
      }
    }
  }
}
